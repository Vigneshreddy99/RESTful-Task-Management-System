# MongoDB Atlas (Recommended - Free Cloud Database)
# Get your connection string from: https://cloud.mongodb.com
# Replace <username>, <password>, and <cluster-url> with your actual values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/taskmanagement?retryWrites=true&w=majority

# OR Local MongoDB (requires MongoDB installed and running)
# MONGO_URI=mongodb://127.0.0.1:27017/taskmanagement

PORT=5000
